    { "id": "hsk1-006", "simplified": "请", "pinyin": "qǐng", "english": "please / invite", "part_of_speech": "verb", "example_sentence": { "simplified": "请坐。", "pinyin": "Qǐng zuò.", "english": "Please sit down." }, "hsk_level": 1, "tags": ["polite"] },
