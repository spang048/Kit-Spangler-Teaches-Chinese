    { "id": "hsk1-025", "simplified": "五", "pinyin": "wǔ", "english": "five", "part_of_speech": "numeral", "example_sentence": { "simplified": "今天是五号。", "pinyin": "Jīntiān shì wǔ hào.", "english": "Today is the 5th." }, "hsk_level": 1, "tags": ["number"] },
