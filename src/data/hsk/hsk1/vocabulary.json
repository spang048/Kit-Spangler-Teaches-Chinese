    { "id": "hsk1-016", "simplified": "不", "pinyin": "bù", "english": "not / no", "part_of_speech": "adverb", "example_sentence": { "simplified": "我不是老师。", "pinyin": "Wǒ bù shì lǎoshī.", "english": "I am not a teacher." }, "hsk_level": 1, "tags": ["negation"] },
    { "id": "hsk1-017", "simplified": "好", "pinyin": "hǎo", "english": "good / fine / well", "part_of_speech": "adjective", "example_sentence": { "simplified": "今天天气很好。", "pinyin": "Jīntiān tiānqì hěn hǎo.", "english": "The weather is very good today." }, "hsk_level": 1, "tags": ["adjective"] },
