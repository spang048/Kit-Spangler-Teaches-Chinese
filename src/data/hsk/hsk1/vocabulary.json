    { "id": "hsk1-011", "simplified": "她", "pinyin": "tā", "english": "she / her", "part_of_speech": "pronoun", "example_sentence": { "simplified": "她叫什么名字？", "pinyin": "Tā jiào shénme míngzi?", "english": "What is her name?" }, "hsk_level": 1, "tags": ["pronoun"] },
    { "id": "hsk1-012", "simplified": "我们", "pinyin": "wǒmen", "english": "we / us", "part_of_speech": "pronoun", "example_sentence": { "simplified": "我们都是朋友。", "pinyin": "Wǒmen dōu shì péngyou.", "english": "We are all friends." }, "hsk_level": 1, "tags": ["pronoun"] },
    { "id": "hsk1-013", "simplified": "叫", "pinyin": "jiào", "english": "to be called / to call", "part_of_speech": "verb", "example_sentence": { "simplified": "我叫司凯德。", "pinyin": "Wǒ jiào Sī Kǎidé.", "english": "My name is Kit." }, "hsk_level": 1, "tags": ["introduction"] },
    { "id": "hsk1-014", "simplified": "名字", "pinyin": "míngzi", "english": "name", "part_of_speech": "noun", "example_sentence": { "simplified": "你的名字是什么？", "pinyin": "Nǐ de míngzi shì shénme?", "english": "What is your name?" }, "hsk_level": 1, "tags": ["introduction"] },
