    { "id": "hsk1-021", "simplified": "一", "pinyin": "yī", "english": "one", "part_of_speech": "numeral", "example_sentence": { "simplified": "我有一个苹果。", "pinyin": "Wǒ yǒu yī gè píngguǒ.", "english": "I have one apple." }, "hsk_level": 1, "tags": ["number"] },
    { "id": "hsk1-022", "simplified": "二", "pinyin": "èr", "english": "two", "part_of_speech": "numeral", "example_sentence": { "simplified": "我有两个朋友。", "pinyin": "Wǒ yǒu liǎng gè péngyou.", "english": "I have two friends." }, "hsk_level": 1, "tags": ["number"] },
    { "id": "hsk1-023", "simplified": "三", "pinyin": "sān", "english": "three", "part_of_speech": "numeral", "example_sentence": { "simplified": "这里有三本书。", "pinyin": "Zhèlǐ yǒu sān běn shū.", "english": "There are three books here." }, "hsk_level": 1, "tags": ["number"] },
